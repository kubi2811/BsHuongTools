# Mẫu cấu hình - copy thành .env rồi điền (KHÔNG commit .env)
HIS_URL=https://your-his-url/
PORT=3000
# Mã PIN đăng nhập giao diện web
PIN=doi-cai-nay

# Tài khoản HIS (để auto-login). KHÔNG commit file .env thật.
HIS_USER=
HIS_PASS=

# Khoa làm việc (popup "Chọn khoa làm việc" sau đăng nhập)
KHOA=Khoa Sản N2

# Bật/tắt điểm dừng xác nhận trước khi bấm Lưu
CONFIRM_BEFORE_SAVE=1
