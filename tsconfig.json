{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "server/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "src/probe*.ts", "src/discover.ts", "src/ui-shot.ts", "src/demo.ts", "src/run-flow1.ts"]
}
